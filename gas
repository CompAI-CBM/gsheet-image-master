/*────────────────────  Vision + Tool image generation  ────────────────────
 * • Sees the pack-shot (file_id) and calls the "image_generation" tool in
 *   the same request, so gpt-image-1 faithfully reproduces the new carton.
 * • Returns { imageB64, callId } for follow-up edits.                         */
function runImageGeneration_(apiKey, fullPrompt, fileId) {
  const url = 'https://api.openai.com/v1/responses';
  const payload = {
    model : 'gpt-4.1-mini',
    input : [
      {
        role    : 'user',
        content : [
          { type : 'input_text',  text   : fullPrompt },
          { type : 'input_image', file_id: fileId    }   // Vision!
        ]
      }
    ],
    tools : [{ type:'image_generation' }]
  };


  const resp = JSON.parse(
    UrlFetchApp.fetch(url, {
      method  : 'post',
      headers : {
        Authorization : 'Bearer ' + apiKey,
        'Content-Type': 'application/json'
      },
      payload            : JSON.stringify(payload),
      muteHttpExceptions : true
    }).getContentText()
  );

  const imgCall = (resp.output || [])
                    .find(o => o.type === 'image_generation_call');
  if (!imgCall)
    throw new Error('No image_generation_call returned.\n' + JSON.stringify(resp));

  return { imageB64: imgCall.result, callId: imgCall.id };
}

/*────────────── Drive helper ───────────────*/
function saveImageToDrive_(asin, colIdxMinus1, imageB64) {
  const ssFile   = DriveApp.getFileById(SpreadsheetApp.getActive().getId());
  const parent   = ssFile.getParents().hasNext() ? ssFile.getParents().next() : DriveApp.getRootFolder();
  const folder   = getOrCreateSubFolder_(parent, 'Images_');
  const blob     = Utilities.newBlob(Utilities.base64Decode(imageB64), 'image/png', `${asin}_${colIdxMinus1}.png`);
  const file     = folder.createFile(blob).setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  return file.getUrl();
}

/*────────────── Folder helper – Images_n ───────────────*/
function getOrCreateSubFolder_(parent, baseName) {
  let n = 1;
  while (true) {
    const name = baseName + n;
    const existing = parent.getFoldersByName(name);
    if (existing.hasNext()) {
      if (existing.next().getFiles().hasNext()) { n++; continue; }  // occupied – bump index
      return existing.next();                                       // empty reuse
    }
    return parent.createFolder(name);                               // fresh
  }
}

/*────────────── Sheet cloning / building ───────────────*/
/*──────── Build or clone IMG_LINKS / IMG_PREVIEWS ────────
 * base  = "IMG_LINKS" or "IMG_PREVIEWS"
 * promSh = the IMG_PROMPTS sheet
 * addGuidelineCol = true  → insert the “Graphical guidelines” column (col B)
 */
function getOrBuildImageSheet_(base, promSh, addGuidelineCol=false) {

  /* ---- clone-when-manual logic (same as before) ---- */
  const viaTrigger = !!ScriptApp.getProjectTriggers()
                     .find(t => t.getHandlerFunction() === 'Generate_MASTER_IMAGES');
  const existing   = getSheetByNameInsensitive_(base);
  const ss         = SpreadsheetApp.getActive();
  let sh;

  if (existing && !viaTrigger) {                       // manual run → clone
    let n = 2;
    while (getSheetByNameInsensitive_(base + '_' + n)) n++;
    sh = existing.copyTo(ss).setName(base + '_' + n);
  } else if (existing) {
    sh = existing;
  } else {
    sh = ss.insertSheet(base);
  }

  /* ---- build header row ---- */
  const headerPrompts = promSh.getRange(1, 1, 1, promSh.getLastColumn())
                              .getValues()[0];         // row 1 of IMG_PROMPTS
  const header = [];
  header.push(headerPrompts[0]);                       // ASIN
  if (addGuidelineCol) header.push('Graphical guidelines');
  header.push(...headerPrompts.slice(1));              // all prompt titles
  header.push('Last conversation');
  header.push('Pack file ID');
  sh.getRange(1, 1, 1, header.length).setValues([header]);

  /* ---- copy ASIN column ---- */
  const asins = promSh.getRange(2, 1, promSh.getLastRow() - 1, 1).getValues();
  sh.getRange(2, 1, asins.length, 1).setValues(asins);

  /* ---- make IMG_PREVIEWS rows square ---- */
  if (base.replace(/[^a-z0-9]/gi, '').toLowerCase() === 'imgpreviews') {
    const colWidth = sh.getColumnWidth(2);             // width of first prompt col
    sh.setRowHeights(2, asins.length, colWidth);
  }

  return sh;
}


/*────────────── Misc helpers ───────────────*/
function lookupPackshot_(asin, cleanSh, colIdx) {
  /* data start at row 3 (skip two header rows) */
  const rows = cleanSh.getRange(3, 1,
                  cleanSh.getLastRow() - 2,          // height
                  colIdx).getValues();

  for (let i = 0; i < rows.length; i++) {
    if (rows[i][0] === asin && rows[i][colIdx - 1]) {
      return rows[i][colIdx - 1];                   // first non-empty hit
    }
  }
  return '';                                         // fallback
}

function findColumnByHeader_(sh, label) {
  const norm = s => s.toString().replace(/[^a-z0-9]/gi, '').toLowerCase();
  const want = norm(label);
  const rows = sh.getRange(1, 1, 2, sh.getLastColumn()).getValues();
  for (let c = 0; c < rows[0].length; c++) {
    if (norm(rows[0][c]) === want || norm(rows[1][c]) === want) return c + 1;
  }
  return -1;
}

