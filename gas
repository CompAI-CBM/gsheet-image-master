/*────────────────────────  GUIDELINE PASS  ────────────────────────
 * • Vision reads the pack-shot (`packLink`) and answers with brand rules.
 * • Returns { text, assistantMsg } where:
 *      text          – plain guidelines (for the sheet’s column)
 *      assistantMsg  – the *entire* assistant message object to keep in context
 */
function runGuidelineCall_(apiKey, guidelinePrompt, packLink) {
  const payload = {
    model : 'gpt-4o-mini',
    input : [{
      role    : 'user',
      content : [
        { type:'input_text',  text: guidelinePrompt },
        { type:'input_image', image_url: packLink }
      ]
    }]
  };

  const resp = JSON.parse(UrlFetchApp.fetch(
    'https://api.openai.com/v1/responses',
    {
      method : 'post',
      headers: { Authorization:'Bearer '+apiKey,
                 'Content-Type':'application/json' },
      payload: JSON.stringify(payload),
      muteHttpExceptions:true
    }
  ).getContentText());

  const msg = (resp.output && resp.output[0]) || null;
  const txt = msg && (msg.text ||
             (msg.content&&msg.content.length&&msg.content[0].text)) || '';
  if (!txt) throw new Error('Empty guideline reply.\n'+JSON.stringify(resp));

  return { text: txt.trim(), assistantMsg: msg };
}

/*───────────────────────────────  Upload pack-shot once  ────────────────────────────────
 * • Looks for an existing file-id in linksSh row → returns it if present.
 * • Otherwise downloads the image, uploads it to /v1/files (purpose:"vision"),
 *   writes the file_id into the “Pack file ID” column, and returns it.           */
function getOrCreateFileId_(apiKey, packLink, linksSh, row, PACK_FILE_COL) {
  let fileId = linksSh.getRange(row, PACK_FILE_COL).getValue();
  if (fileId) return fileId;                      // already cached

  // 1 — download the image
  const blob = UrlFetchApp.fetch(packLink).getBlob();

  // 2 — upload to OpenAI Files
  const uploadResp = JSON.parse(UrlFetchApp.fetch(
    'https://api.openai.com/v1/files',
    {
      method : 'post',
      headers: { Authorization : 'Bearer ' + apiKey },
      payload: {
        purpose : 'vision',
        file    : blob
      },
      muteHttpExceptions : true
    }
  ).getContentText());

  if (!uploadResp.id)
    throw new Error('Pack-shot upload failed: ' + JSON.stringify(uploadResp));

  // 3 — cache in sheet
  linksSh.getRange(row, PACK_FILE_COL).setValue(uploadResp.id);
  return uploadResp.id;
}

/*────────  VISION + TOOL  with conversation context  ────────
 * • inputArr = previous assistantMsg + tool calls  (JSON.parse from sheet)
 * • fileId   = pack-shot file ID  (added every turn so model sees the carton)
 * Returns { imageB64, toolCallObj }  (toolCallObj must be appended to context)
 */
function runImageGenerationWithContext_(apiKey, inputArr, userPrompt, imgUrl) {

  /* ---------- build user message ---------- */
  const userContent = [{ type: 'input_text', text: userPrompt }];
  if (imgUrl) {                                        // attach as URL
    userContent.push({ type: 'input_image', image_url: imgUrl });
  }
  const userMsg = { role: 'user', content: userContent };

  const payload = {
    model : 'gpt-4.1-mini',
    input : [...inputArr, userMsg],
    tools : [{ type:'image_generation' }]
  };

  const resp = JSON.parse(UrlFetchApp.fetch(
    'https://api.openai.com/v1/responses',
    {
      method : 'post',
      headers: { Authorization:'Bearer '+apiKey,
                 'Content-Type':'application/json' },
      payload: JSON.stringify(payload),
      muteHttpExceptions:true
    }
  ).getContentText());
  
  const tc = (resp.output || []).find(o => o.type === 'image_generation_call');
  if (!tc) {
    /* ↳ model returned plain text instead of an image — keep going */
    const assistant = (resp.output || []).find(o => o.type === 'message');
    const txt = assistant && assistant.content && assistant.content.length
                ? (assistant.content[0].text || '').trim()
                : '';
    return { imageB64: '', toolCallObj: null, assistantText: txt };   // SAFELY FALL BACK
  }


  /* KEEP ONLY type + id  (discard the huge base-64 “result”) */
  const stub = { type: tc.type, id: tc.id };

  return { imageB64: tc.result, toolCallObj: stub };

}

/* Extract the tool-call ID from an image_generation response body */
function extractToolCallId_(rawJson) {
  try {
    const j = JSON.parse(rawJson);
    const tc = (j.output || []).find(o => o.type === 'image_generation_call');
    return tc ? tc.id : '';
  } catch (_) {
    return '';
  }
}

/*──────────────────────────────────────────────────────────────
 * Generate_COPY_FEED
 * • Builds / refreshes COPY_FEED sheet (clone of REFINED_PROMPTS)
 * • One GPT-4.1 call per non-blank cell (B2…last)
 * • System prompt = SETUP["extract_copy_feed"]
 * • User prompt   = cell content in REFINED_PROMPTS
 * • Result is pasted VERBATIM (markdown row) into COPY_FEED
 * • “DISMISS*” cells are copied as DISMISSED (no API call)
 * • Logs every call in LOG_Generate COPY_FEED   (7-col header)
 *──────────────────────────────────────────────────────────────*/
const LOG_COPY_SHEET = 'LOG_Generate COPY_FEED';

function Generate_COPY_FEED() {
  const ss = SpreadsheetApp.getActive();
  const t0 = Date.now();

  /*──── SETUP – keys ────*/
  const setup = getNamedSetupValues_(['OPENAI_API_KEY','extract_copy_feed']);
  const apiKey = setup.OPENAI_API_KEY || '';
  const sysPrompt = setup.extract_copy_feed || '';
  if (!apiKey || !sysPrompt) { safeAlert('SETUP missing OPENAI_API_KEY or extract_copy_feed'); return; }

  /*──── source / target sheets ────*/
  const srcSh = getSheetByNameInsensitive_('REFINED_PROMPTS');
  if (!srcSh) { safeAlert('REFINED_PROMPTS sheet not found'); return; }
  const tgtSh = buildOrRefreshTargetSheet_('COPY_FEED', srcSh);

  /*──── helper : single chat-completion ────*/
  function runCopyAssistant_(userTxt){
    const payload = {
      model: 'gpt-4.1',
      messages:[
        {role:'system',content:sysPrompt},
        {role:'user',  content:userTxt}
      ]
    };
    for (let attempt=0;attempt<2;attempt++){
      const resp = UrlFetchApp.fetch(
        'https://api.openai.com/v1/chat/completions',{
          method:'post',
          headers:{Authorization:'Bearer '+apiKey,'Content-Type':'application/json'},
          payload:JSON.stringify(payload),
          muteHttpExceptions:true
        });
      const raw = resp.getContentText();
      if (resp.getResponseCode()!==200) { Utilities.sleep(RETRY_DELAY); continue; }
      try{
        const txt = JSON.parse(raw).choices[0].message.content || '';
        return {text:txt, raw};
      }catch(_){}
      Utilities.sleep(RETRY_DELAY);
    }
    return {text:'',raw:'FAILED'};
  }

  /*──── helper : logger ────*/
  function logCopy_(asin, header, status, userMsg, raw){
    const sh = ensureSheet_(LOG_COPY_SHEET);
    if (sh.getLastRow()===0){
      sh.appendRow(['Timestamp','ASIN','Header','Status','System msg','User msg','OpenAI raw']);
    }
    sh.appendRow([new Date(),asin,header,status,sysPrompt,userMsg,raw]);
  }

  /*──── main double loop ────*/
  const lastRow = srcSh.getLastRow();
  const lastCol = srcSh.getLastColumn();

  for (let r=2;r<=lastRow;r++){
    const asin = String(srcSh.getRange(r,1).getValue()).trim();
    if (!asin) break;

    for (let c=2;c<=lastCol;c++){
      const colHeader = header_(srcSh,c);
      const userMsg = String(srcSh.getRange(r,c).getValue()).trim();

      if (!userMsg){
        /* early-terminate row if the rest is blank */
        const restBlank = srcSh.getRange(r,c,lastCol-c+1).getValues()[0]
                          .every(v=>!String(v).trim());
        if (restBlank) break;
        continue;
      }

      /* DISMISS shortcut */
      if (/^dismiss/i.test(userMsg)){
        tgtSh.getRange(r,c).setValue('DISMISSED');
        continue;
      }

      /* GPT-4.1 call */
      const {text,raw} = runCopyAssistant_(userMsg);
      const status = text ? 'OK' : 'FAIL';
      tgtSh.getRange(r,c).setValue(text || '');       // verbatim markdown line
      logCopy_(asin,colHeader,status,userMsg,raw);

      Utilities.sleep(RATE_DELAY);
      if (Date.now()-t0 > MAX_RUNTIME_MS){
        ScriptApp.newTrigger('Generate_COPY_FEED').timeBased().after(10000).create();
        safeAlert('25-minute limit – COPY_FEED will resume in 10 s.');
        return;
      }
    }
  }
  safeAlert('Generate COPY_FEED completed.');
}

/*──────────────────────────────────────────────────────────────
 * Create_FIGMA_FEED  – one line per SKU, wide column set
 *──────────────────────────────────────────────────────────────*/
function Create_FIGMA_FEED() {

  /* --- locate all required sheets (case-insensitive) --- */
  const srcSh  = getSheetByNameInsensitive_('REFINED_PROMPTS');
  const copySh = getSheetByNameInsensitive_('COPY_FEED');
  const mainSh = getSheetByNameInsensitive_('MASTER_IMAGES');
  const bgSh   = getSheetByNameInsensitive_('MASTER_BACKGROUND');
  const olSh   = getSheetByNameInsensitive_('MASTER_OVERLAY');

  if (!srcSh || !copySh || !mainSh || !bgSh || !olSh) {
    safeAlert('One of the required sheets (REFINED_PROMPTS / COPY_FEED / MASTER_* ) is missing.');
    return;
  }

  /* --- read source data --- */
  const promVals = srcSh.getDataRange().getValues();          // prompts
  const copyVals = copySh.getDataRange().getValues();         // pipe text
  const mainVals = mainSh.getDataRange().getValues();         // links
  const bgVals   = bgSh.getDataRange().getValues();
  const olVals   = olSh.getDataRange().getValues();

  const skuRows   = promVals.length - 1;                      // exclude header
  const tileCount = promVals[0].length - 1;                   // columns B…last

  /* --- build the wide header --- */
  const letters = ['a','b','c','d','e','f','g','h','i','j'];  // 10 text fields
  const header  = ['ID'];
  for (let n = 1; n <= tileCount; n++) {
    header.push(`Frame${n}`, `ref${n}`, `main${n}`, `bg${n}`, `ol${n}`);
    letters.forEach(l => header.push(`tx${l}${n}`));
  }

  /* --- (re)create FIGMA_FEED sheet --- */
  const ss  = SpreadsheetApp.getActive();
  const tgt = getSheetByNameInsensitive_('FIGMA_FEED')
              ? getSheetByNameInsensitive_('FIGMA_FEED').clear()
              : ss.insertSheet('FIGMA_FEED');
  tgt.getRange(1,1,1,header.length).setValues([header]);

  /* --- helper: returns 10-cell text array from pipe-string --- */
  const splitTen = txt => {
    const arr = txt.split('|').map(s => s.trim() || '-');
    while (arr.length < 10) arr.push('-');
    return arr.slice(0,10);
  };

  /* --- build all SKU rows --- */
  const output = [];
  for (let r = 1; r <= skuRows; r++) {                      // sheet row index (data starts at 2)
    const asin = String(promVals[r][0]).trim();
    if (!asin) break;

    const row = [r];                                        // ID column (1-based sequential)
    for (let t = 1; t <= tileCount; t++) {
      const promptCell = String(promVals[r][t]).trim();
      const isDismiss  = /^dismiss/i.test(promptCell);

      /* static cells */
      row.push('#ffffff');          // Frame<n>
      row.push(asin);               // ref<n>

      /* image links or DISMISSED */
      const mainLink = String(mainVals[r][t]).trim();
      const bgLink   = String(bgVals[r][t]).trim();
      const olLink   = String(olVals[r][t]).trim();
      row.push(isDismiss ? 'DISMISSED' : mainLink);
      row.push(isDismiss ? 'DISMISSED' : bgLink);
      row.push(isDismiss ? 'DISMISSED' : olLink);

      /* ten text cells */
      const copyCell = String(copyVals[r][t]).trim();
      const txArr    = isDismiss ? new Array(10).fill('DISMISSED')
                                 : splitTen(copyCell);
      row.push(...txArr);
    }
    output.push(row);
  }

  /* --- write to sheet --- */
  if (output.length) tgt.getRange(2,1,output.length,header.length).setValues(output);

  safeAlert('Create FIGMA_FEED completed. Rows added: ' + output.length);
}

function convertDriveLinks() {
  const sheet = SpreadsheetApp.getActiveSheet();
  const range = sheet.getDataRange();
  const values = range.getValues();

  const ucRegex = /https:\/\/drive\.google\.com\/uc\?export=view&id=([a-zA-Z0-9_-]+)/g;

  for (let i = 0; i < values.length; i++) {
    for (let j = 0; j < values[i].length; j++) {
      let cell = values[i][j];
      if (typeof cell === 'string' && cell.includes('drive.google.com/uc?export=view&id=')) {
        values[i][j] = cell.replace(ucRegex, 'https://drive.google.com/thumbnail?id=$1&sz=w1000');
      }
    }
  }

  range.setValues(values);
  SpreadsheetApp.getUi().alert('✅ Drive links converted to thumbnail format.');
}

